{
  "name": "react-native-boost-example",
  "version": "0.0.1",
  "main": "index.ts",
  "scripts": {
    "gen:unoptimized": "node scripts/gen-unoptimized.mjs",
    "prestart": "node scripts/gen-unoptimized.mjs",
    "preandroid": "node scripts/gen-unoptimized.mjs",
    "preios": "node scripts/gen-unoptimized.mjs",
    "typecheck": "tsc --noEmit",
    "start": "expo start",
    "dev": "expo start",
    "android": "rm -rf android && expo run:android",
    "ios": "rm -rf ios && expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "expo": "^55.0.3",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-boost": "workspace:*",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-time-to-render": "workspace:*",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.14",
    "typescript": "~5.9.3"
  },
  "private": true
}
